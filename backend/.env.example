# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5545/objective_content

# --- Portal credentials + URLs (read by portal/constants.py) ---
PORTAL_PROD_BASE_URL=
# PORTAL_PROD_USERNAME=content_loader
PORTAL_PROD_PASSWORD=changeme
PORTAL_BETA_BASE_URL=
# PORTAL_BETA_USERNAME=content_loader
PORTAL_BETA_PASSWORD=changeme
PORTAL_LEARNING_COURSE_URL=
# PORTAL_FETCH_CONCURRENCY=8

# --- RAG: OpenRouter (embeddings + judge chat) ---
OPENROUTER_API_KEY=changeme
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBED_MODEL=text-embedding-3-large
EMBED_DIMENSIONS=1536
RAG_CHAT_MODEL=openai/gpt-4o-mini

# --- MCQ pipeline (LangGraph) ---
MCQ_AGENT_MODEL=openai/gpt-4o

# --- Internal OpenAI-compatible LLM proxy (seeds the inactive "proxy" connector preset) ---
PROXY_BASE_URL=
PROXY_API_KEY=
# OPENAI_API_KEY is the fallback for the proxy key when PROXY_API_KEY is unset.
OPENAI_API_KEY=

# --- Secret for encrypting stored LLM provider API keys (Fernet). Set in real deploys. ---
LLM_SECRET_KEY=

# --- LangSmith tracing (optional; leave disabled to skip) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=objective-content-mcq
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Beta content-loading S3 export (temporary upload target) ---
BETA_ADMIN_BASE_URL=
BETA_ADMIN_USERNAME=content_loader
BETA_ADMIN_PASSWORD=changeme
# BETA_S3_BUCKET=nkb-backend-ccbp-media-static
# BETA_S3_REGION=ap-south-1

# --- Exam-config Google Sheet (copy template → fill Form tab → submit load) ---
# Path to a Google service-account JSON (gitignored). The template sheet must be
# shared with that service account's client_email as Editor.
# GOOGLE_SA_CREDENTIALS_FILE=google_sa_credentials.json
# MCQ_TEMPLATE_SPREADSHEET_ID=1Grps-VAstCkmquzC_oDOAMnpYWrFNsXUXDf5RrzCFm4
# MCQ_SHEET_SHARE_EMAILS=learningresource@nkblearningbackend.iam.gserviceaccount.com,jeevansravanth.parisa@nxtwave.co.in
# BETA_LOAD_POLL_TIMEOUT=180

# --- Auth (JWT) ---
# REQUIRED in any real deployment. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SECRET=
# JWT_EXPIRE_MINUTES=10080
# LOG_LEVEL=INFO

APP_ENV=local

